{
  "name": "@burnt-labs/xion-types",
  "version": "0.0.1",
  "author": "burnt-labs <devops@burnt.com>",
  "description": "xion-types",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "homepage": "https://github.com/burnt-labs/xion-types",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/burnt-labs/xion-types"
  },
  "bugs": {
    "url": "https://github.com/burnt-labs/xion-types/issues"
  },
  "scripts": {
    "copy": "copyfiles -f ./LICENSE README.md package.json dist && copyfiles -u 1 'types/contracts/*/schema/**/*.json' dist",
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc && tsc -p tsconfig.esm.json && pnpm run copy",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@cosmwasm/ts-codegen": "1.12.1",
    "@types/node": "^22.14.1",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.0.1",
    "ts-proto": "2.11.5",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.8.0",
    "@improbable-eng/grpc-web": "^0.15.0",
    "browser-headers": "^0.4.1"
  },
  "peerDependencies": {
    "@cosmjs/proto-signing": ">=0.32.3",
    "@cosmjs/stargate": ">=0.32.3",
    "@cosmjs/tendermint-rpc": ">=0.32.3"
  },
  "keywords": [],
  "packageManager": "pnpm@9.15.4"
}
