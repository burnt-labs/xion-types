{
  "name": "@burnt-labs/xion-types",
  "version": "28.1.0",
  "author": "burnt-labs <devops@burnt.com>",
  "description": "xion-types (Telescope-generated with Amino, LCD, RPC clients)",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "homepage": "https://github.com/burnt-labs/xion-types",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/burnt-labs/xion-types"
  },
  "bugs": {
    "url": "https://github.com/burnt-labs/xion-types/issues"
  },
  "scripts": {
    "copy": "copyfiles -f ./LICENSE README.md package.json dist",
    "clean": "rimraf dist",
    "download-protos": "ts-node scripts/download-protos.ts",
    "codegen": "ts-node scripts/codegen.ts",
    "build": "pnpm run clean && tsc && tsc -p tsconfig.esm.json && pnpm run copy",
    "build:dev": "pnpm run clean && pnpm run codegen && tsc --declarationMap && tsc -p tsconfig.esm.json && pnpm run copy",
    "lint": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.8.0",
    "@cosmology/lcd": "^0.14.0",
    "@cosmology/telescope": "^1.12.20",
    "@improbable-eng/grpc-web": "^0.15.0",
    "@interchainjs/cosmos": "1.11.5",
    "@interchainjs/cosmos-types": "1.11.5",
    "@interchainjs/encoding": "1.11.5",
    "@interchainjs/pubkey": "1.11.5",
    "@interchainjs/types": "1.11.5",
    "@interchainjs/utils": "1.11.5"
  },
  "peerDependencies": {
    "@cosmjs/amino": "^0.36.0",
    "@cosmjs/cosmwasm-stargate": "^0.36.0",
    "@cosmjs/encoding": "^0.36.0",
    "cosmjs-types": "^0.9.0"
  },
  "peerDependenciesMeta": {
    "@cosmjs/amino": {
      "optional": true
    },
    "@cosmjs/cosmwasm-stargate": {
      "optional": true
    },
    "@cosmjs/encoding": {
      "optional": true
    },
    "cosmjs-types": {
      "optional": true
    }
  },
  "keywords": [],
  "packageManager": "pnpm@9.15.4"
}
